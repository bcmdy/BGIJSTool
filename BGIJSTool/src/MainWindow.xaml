<Window x:Class="BGIJSTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BetterGI 脚本管理工具" Height="600" Width="800"
        Loaded="Window_Loaded">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 第0行：路径标签 -->
        <TextBlock Grid.Row="0" Text="BetterGI.exe 路径:" FontWeight="Bold" Margin="0,0,0,6"/>

        <!-- 第1行：路径文本 + 浏览按钮 -->
        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" x:Name="BGIPathText" Text="" Foreground="Red"
                       TextWrapping="Wrap" VerticalAlignment="Center"/>
            <Button Grid.Column="1" x:Name="BrowseBtn" Content="浏览…" Width="70"
                    Margin="6,0,0,0" Click="BrowseBtn_Click" VerticalAlignment="Center"/>
        </Grid>

        <!-- 第2行：选择模块 -->
        <Grid Grid.Row="2" Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="选择模块:" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <ComboBox Grid.Column="1" x:Name="ModuleCombo" DisplayMemberPath="name"/>
        </Grid>

        <!-- 第3行：执行按钮 -->
        <Button Grid.Row="3" x:Name="ExecuteBtn" Content="执行" Width="80"
                HorizontalAlignment="Right" Margin="0,0,0,6"
                Click="ExecuteBtn_Click"/>

        <!-- 第4行：刷新配置 -->
        <Button Grid.Row="4" Content="刷新配置" Width="80"
                HorizontalAlignment="Right" Margin="0,0,0,8"
                Click="RefreshBtn_Click"/>

        <!-- 第5行：日志 -->
        <Border Grid.Row="5" BorderBrush="Gray" BorderThickness="1" Margin="0,0,0,10">
            <RichTextBox x:Name="LogBox" IsReadOnly="True" BorderThickness="0"
                         VerticalScrollBarVisibility="Auto"
                         Background="#FFF8F8F8"/>
        </Border>

        <!-- 第6行：状态栏 -->
        <StatusBar Grid.Row="6">
            <StatusBarItem>
                <TextBlock x:Name="StatusText" Text="就绪"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
